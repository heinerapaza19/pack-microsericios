# Production profile for docker-compose
SPRING_PROFILES_ACTIVE=prod

# Config Server
CONFIG_SERVER_URL=http://config-server:7071

# MySQL credentials
USER_MYSQL_ROOT_PASSWORD=root
USER_MYSQL_DATABASE=user_db

# Spring datasource (USER service)
USER_DB_HOST=mysql-user
USER_DB_PORT=3306
USER_DB_NAME=user_db
USER_DB_USERNAME=root
USER_DB_PASSWORD=root